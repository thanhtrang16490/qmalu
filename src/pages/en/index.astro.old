const seoTitle = "Quang Minh - Industrial Aluminum and Solar Energy Manufacturing"
const seoDescription = "Quang Minh specializes in manufacturing and processing solar energy electrical equipment accessories and A6005 industrial aluminum. Super durable, fire-resistant, easy to clean products. 3,000m² factory at Nguyen Khe Industrial Park, Phuc Thinh Commune, Hanoi."
