---
interface Product {
  id: string
  name: string
  price: number | null
  unit: string
}

interface Props {
  lang?: 'vi' | 'en' | 'cn'
  products: Product[]
}

const { lang = 'vi', products = [] } = Astro.props

const t = {
  vi: { step1Title: 'Thông tin liên hệ', step2Title: 'Chọn sản phẩm', step1Subtitle: 'Vui lòng điền thông tin của bạn', step2Subtitle: 'Chọn sản phẩm và số lượng cần báo giá', name: 'Họ và tên', namePlaceholder: 'Nguyễn Văn A', phone: 'Số điện thoại', phonePlaceholder: '0912 345 678', email: 'Email', emailPlaceholder: 'email@example.com', company: 'Công ty', companyPlaceholder: 'Tên công ty (không bắt buộc)', message: 'Ghi chú', messagePlaceholder: 'Yêu cầu đặc biệt...', next: 'Tiếp theo', back: 'Quay lại', cancel: 'Hủy', submit: 'Gửi yêu cầu báo giá', searchProduct: 'Tìm sản phẩm...', noProducts: 'Chưa chọn sản phẩm nào', orderTotal: 'Tổng đơn hàng', vat: 'VAT (10%)', grandTotal: 'Tổng cộng' },
  en: { step1Title: 'Contact Information', step2Title: 'Select Products', step1Subtitle: 'Please fill in your information', step2Subtitle: 'Select products and quantities for quote', name: 'Full Name', namePlaceholder: 'John Doe', phone: 'Phone Number', phonePlaceholder: '+84 912 345 678', email: 'Email', emailPlaceholder: 'email@example.com', company: 'Company', companyPlaceholder: 'Company name (optional)', message: 'Notes', messagePlaceholder: 'Special requirements...', next: 'Next', back: 'Back', cancel: 'Cancel', submit: 'Send Quote Request', searchProduct: 'Search products...', noProducts: 'No products selected', orderTotal: 'Subtotal', vat: 'VAT (10%)', grandTotal: 'Total' },
  cn: { step1Title: '联系信息', step2Title: '选择产品', step1Subtitle: '请填写您的信息', step2Subtitle: '选择产品和数量以获取报价', name: '姓名', namePlaceholder: '张三', phone: '电话号码', phonePlaceholder: '+84 912 345 678', email: '电子邮件', emailPlaceholder: 'email@example.com', company: '公司', companyPlaceholder: '公司名称（可选）', message: '备注', messagePlaceholder: '特殊要求...', next: '下一步', back: '返回', cancel: '取消', submit: '发送报价请求', searchProduct: '搜索产品...', noProducts: '未选择产品', orderTotal: '小计', vat: '增值税 (10%)', grandTotal: '总计' }
}[lang]

const productsJson = JSON.stringify(products.map(p => ({ id: p.id, name: p.name, price: p.price || 0, unit: p.unit })))
---

<div id="multistep-quote-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="multistep-modal-backdrop"></div>
  
  <div class="relative bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <div class="bg-white border-b border-gray-200 px-6 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-semibold text-gray-900" id="modal-title">{t.step1Title}</h2>
          <p class="text-sm text-gray-600 mt-1" id="modal-subtitle">{t.step1Subtitle}</p>
        </div>
        <button id="close-multistep-modal" class="p-2 hover:bg-gray-100 rounded-lg transition-colors">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="flex items-center gap-2 mt-4">
        <div class="flex items-center gap-2 flex-1">
          <div class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center text-sm font-medium" id="step1-indicator">1</div>
          <div class="text-sm font-medium text-gray-900" id="step1-label">{t.step1Title}</div>
        </div>
        <div class="w-12 h-0.5 bg-gray-200" id="progress-line"></div>
        <div class="flex items-center gap-2 flex-1">
          <div class="w-8 h-8 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-sm font-medium" id="step2-indicator">2</div>
          <div class="text-sm font-medium text-gray-500" id="step2-label">{t.step2Title}</div>
        </div>
      </div>
    </div>


    <div class="flex-1 overflow-y-auto">
      <div id="step1-content" class="p-6">
        <form id="contact-form" class="space-y-4 max-w-2xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1">{t.name} <span class="text-red-500">*</span></label>
              <input type="text" name="name" required placeholder={t.namePlaceholder} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1">{t.phone} <span class="text-red-500">*</span></label>
              <input type="tel" name="phone" required placeholder={t.phonePlaceholder} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1">{t.email} <span class="text-red-500">*</span></label>
              <input type="email" name="email" required placeholder={t.emailPlaceholder} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1">{t.company}</label>
              <input type="text" name="company" placeholder={t.companyPlaceholder} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-900 mb-1">{t.message}</label>
            <textarea name="message" placeholder={t.messagePlaceholder} rows="3" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm resize-none"></textarea>
          </div>
        </form>
      </div>

      <div id="step2-content" class="p-6 hidden">
        <div class="mb-4">
          <input type="text" id="product-search" placeholder={t.searchProduct} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm" />
        </div>
        <div class="grid grid-cols-1 gap-3 mb-6 max-h-96 overflow-y-auto" id="product-list"></div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <h3 class="font-semibold text-gray-900 mb-3">{t.orderTotal}</h3>
          <div id="selected-products" class="space-y-2 mb-3 text-sm max-h-40 overflow-y-auto">
            <p class="text-gray-500 text-center py-4">{t.noProducts}</p>
          </div>
          <div class="border-t border-gray-300 pt-3 space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-gray-600">{t.orderTotal}:</span><span class="font-medium" id="subtotal">0đ</span></div>
            <div class="flex justify-between"><span class="text-gray-600">{t.vat}:</span><span class="font-medium" id="vat-amount">0đ</span></div>
            <div class="flex justify-between text-base font-semibold border-t border-gray-300 pt-2"><span>{t.grandTotal}:</span><span class="text-blue-600" id="grand-total">0đ</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-200 px-6 py-4 bg-gray-50">
      <div class="flex gap-3">
        <button type="button" id="cancel-multistep-button" class="px-4 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">{t.cancel}</button>
        <button type="button" id="back-button" class="hidden px-4 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">{t.back}</button>
        <div class="flex-1"></div>
        <button type="button" id="next-button" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">{t.next}</button>
        <button type="submit" id="submit-button" class="hidden px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">{t.submit}</button>
      </div>
    </div>
  </div>
</div>


<script define:vars={{ productsJson, t }}>
  const products = JSON.parse(productsJson)
  let currentStep = 1, selectedProducts = {}, contactInfo = {}

  const modal = document.getElementById('multistep-quote-modal')
  const buttons = {
    close: document.getElementById('close-multistep-modal'),
    cancel: document.getElementById('cancel-multistep-button'),
    next: document.getElementById('next-button'),
    back: document.getElementById('back-button'),
    submit: document.getElementById('submit-button'),
    header: document.getElementById('header-quote-button'),
    mobile: document.getElementById('mobile-quote-button'),
    footer: document.getElementById('footer-quote-button'),
    product: document.getElementById('quote-button')
  }
  const backdrop = document.getElementById('multistep-modal-backdrop')
  const contactForm = document.getElementById('contact-form')

  function openModal() {
    if (modal) {
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      document.body.style.overflow = 'hidden'
      currentStep = 1
      showStep(1)
      renderProducts()
    }
  }

  function closeModal() {
    if (modal) {
      modal.classList.add('hidden')
      modal.classList.remove('flex')
      document.body.style.overflow = ''
      selectedProducts = {}
      if (contactForm) contactForm.reset()
    }
  }

  function showStep(step) {
    const els = {
      step1Content: document.getElementById('step1-content'),
      step2Content: document.getElementById('step2-content'),
      step1Indicator: document.getElementById('step1-indicator'),
      step2Indicator: document.getElementById('step2-indicator'),
      step1Label: document.getElementById('step1-label'),
      step2Label: document.getElementById('step2-label'),
      progressLine: document.getElementById('progress-line'),
      modalTitle: document.getElementById('modal-title'),
      modalSubtitle: document.getElementById('modal-subtitle')
    }

    if (step === 1) {
      els.step1Content?.classList.remove('hidden')
      els.step2Content?.classList.add('hidden')
      els.step1Indicator?.classList.add('bg-blue-600', 'text-white')
      els.step1Indicator?.classList.remove('bg-gray-200', 'text-gray-500')
      els.step2Indicator?.classList.add('bg-gray-200', 'text-gray-500')
      els.step2Indicator?.classList.remove('bg-blue-600', 'text-white')
      els.step1Label?.classList.add('text-gray-900')
      els.step1Label?.classList.remove('text-gray-500')
      els.step2Label?.classList.add('text-gray-500')
      els.step2Label?.classList.remove('text-gray-900')
      els.progressLine?.classList.remove('bg-blue-600')
      els.progressLine?.classList.add('bg-gray-200')
      buttons.next?.classList.remove('hidden')
      buttons.submit?.classList.add('hidden')
      buttons.back?.classList.add('hidden')
      if (els.modalTitle) els.modalTitle.textContent = t.step1Title
      if (els.modalSubtitle) els.modalSubtitle.textContent = t.step1Subtitle
    } else {
      els.step1Content?.classList.add('hidden')
      els.step2Content?.classList.remove('hidden')
      els.step2Indicator?.classList.add('bg-blue-600', 'text-white')
      els.step2Indicator?.classList.remove('bg-gray-200', 'text-gray-500')
      els.step2Label?.classList.add('text-gray-900')
      els.step2Label?.classList.remove('text-gray-500')
      els.progressLine?.classList.add('bg-blue-600')
      els.progressLine?.classList.remove('bg-gray-200')
      buttons.next?.classList.add('hidden')
      buttons.submit?.classList.remove('hidden')
      buttons.back?.classList.remove('hidden')
      if (els.modalTitle) els.modalTitle.textContent = t.step2Title
      if (els.modalSubtitle) els.modalSubtitle.textContent = t.step2Subtitle
    }
  }

  function renderProducts() {
    const productList = document.getElementById('product-list')
    if (!productList) return

    productList.innerHTML = products.map(p => `
      <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:border-blue-300 transition-colors product-item">
        <div class="flex-1">
          <div class="font-medium text-sm text-gray-900">${p.name}</div>
          <div class="text-xs text-gray-500">${p.price.toLocaleString('vi-VN')}đ/${p.unit}</div>
        </div>
        <input type="number" min="0" value="${selectedProducts[p.id] || 0}" data-product-id="${p.id}" class="product-quantity w-20 px-2 py-1.5 border border-gray-300 rounded text-sm text-center" placeholder="0" />
      </div>
    `).join('')

    document.querySelectorAll('.product-quantity').forEach(input => {
      input.addEventListener('input', (e) => {
        const id = e.target.dataset.productId
        const qty = parseInt(e.target.value) || 0
        if (qty > 0) selectedProducts[id] = qty
        else delete selectedProducts[id]
        updateOrderSummary()
      })
    })
  }

  function updateOrderSummary() {
    const div = document.getElementById('selected-products')
    const subtotalEl = document.getElementById('subtotal')
    const vatEl = document.getElementById('vat-amount')
    const grandTotalEl = document.getElementById('grand-total')
    if (!div) return

    const items = Object.entries(selectedProducts).map(([id, qty]) => {
      const p = products.find(x => x.id === id)
      return p ? { ...p, quantity: qty } : null
    }).filter(Boolean)

    if (items.length === 0) {
      div.innerHTML = `<p class="text-gray-500 text-center py-4">${t.noProducts}</p>`
      if (subtotalEl) subtotalEl.textContent = '0đ'
      if (vatEl) vatEl.textContent = '0đ'
      if (grandTotalEl) grandTotalEl.textContent = '0đ'
      return
    }

    div.innerHTML = items.map(i => `<div class="flex justify-between text-gray-700"><span>${i.name} x${i.quantity}</span><span>${(i.price * i.quantity).toLocaleString('vi-VN')}đ</span></div>`).join('')

    const subtotal = items.reduce((sum, i) => sum + (i.price * i.quantity), 0)
    const vat = subtotal * 0.1
    const grandTotal = subtotal + vat

    if (subtotalEl) subtotalEl.textContent = subtotal.toLocaleString('vi-VN') + 'đ'
    if (vatEl) vatEl.textContent = vat.toLocaleString('vi-VN') + 'đ'
    if (grandTotalEl) grandTotalEl.textContent = grandTotal.toLocaleString('vi-VN') + 'đ'
  }

  // Event listeners
  if (buttons.header) buttons.header.addEventListener('click', openModal)
  if (buttons.mobile) buttons.mobile.addEventListener('click', openModal)
  if (buttons.footer) buttons.footer.addEventListener('click', openModal)
  if (buttons.product) buttons.product.addEventListener('click', openModal)

  buttons.close?.addEventListener('click', closeModal)
  buttons.cancel?.addEventListener('click', closeModal)
  backdrop?.addEventListener('click', closeModal)

  buttons.next?.addEventListener('click', () => {
    if (contactForm?.checkValidity()) {
      contactInfo = Object.fromEntries(new FormData(contactForm).entries())
      currentStep = 2
      showStep(2)
    } else contactForm?.reportValidity()
  })

  buttons.back?.addEventListener('click', () => { currentStep = 1; showStep(1) })

  buttons.submit?.addEventListener('click', () => {
    console.log('Quote:', { contact: contactInfo, products: selectedProducts })
    alert('Cảm ơn! Chúng tôi sẽ gửi báo giá chi tiết qua email trong vòng 24h.')
    closeModal()
  })

  const searchInput = document.getElementById('product-search')
  searchInput?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase()
    document.querySelectorAll('.product-item').forEach(item => {
      item.style.display = item.textContent.toLowerCase().includes(query) ? 'flex' : 'none'
    })
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal()
  })
</script>
